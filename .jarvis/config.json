{
  "openai_api_key": "",
  "vault_path": "/home/tatel/Desktop/Tates Brain",
  "realtime_model": "gpt-realtime",
  "voice": "arbor",
  "sample_rate_out": 24000,
  "sample_rate_in": 16000,
  "mic_device": null,
