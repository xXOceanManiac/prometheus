  },
  "ptt_key": "esc",
  "ptt_hold_seconds": 0.25,
  "projects": {
    "jarvis": {
      "path": "/home/tatel/Desktop/Jarvis.v2"
    },
    "microschoolflorida": {
      "path": "/home/tatel/Desktop/microschoolflorida"
    }
  },
  "routines": {
    "microschool_website_changes": {
      "context_name": "Microschool Florida Website Changes",
      "apps": [
        "spotify",
        "chrome"
      ],
      "url_keys": [
        "chatgpt",
        "site_mgr_msf",
        "clickfunnels",
        "zohoflow",
        "trello_msf"
      ],
      "layout": "microschool_web",
      "tags": [
        "website",
        "microschool",
        "marketing",
        "cloud"
      ],
      "description": "Open the Microschool Florida cloud website editing stack.",
      "steps": [
        {
          "action": "open_app",
          "app": "spotify"
        },
        {
          "action": "open_url_keys",
          "url_keys": [
            "chatgpt",
            "site_mgr_msf",
            "clickfunnels",
            "zohoflow",
            "trello_msf"
          ]
        }
      ]
    },
    "movie_mode_full": {
      "description": "Turn on movie mode through Home Assistant.",
      "steps": [
        {
          "action": "run_ha_script",
          "script_name": "jarvis_lights_scene_movie"
        }
      ]
    },
    "netflix_on_xbox": {
      "description": "Launch Netflix on Xbox through Home Assistant.",
      "steps": [
        {
          "action": "run_ha_script",
          "script_name": "jarvis_routine_watch_netflix"
        }
      ]
    }
  }
}